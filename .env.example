# ---------------------------------------------------------------------------
# Llewellyn Fleet — environment variables
# Copy this file to ".env.local" for local development, and set the SAME keys
# in the Railway dashboard for production. NEVER commit real secrets to git.
# ---------------------------------------------------------------------------

# Postgres connection string.
# Local dev: a local Postgres, e.g. postgresql://postgres:postgres@localhost:5432/fleet
# Railway: copy the DATABASE_URL that the Railway Postgres plugin provides
#          (use the private/internal URL so traffic stays on Railway's network).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fleet"

# Secret used to sign login sessions. Generate one with:  openssl rand -base64 32
# Set a long random value in Railway. Keep it secret.
AUTH_SECRET="replace-with-a-long-random-string"

# Where uploaded files (insurance/registration PDFs, receipts, issue photos) are stored.
# Local dev: ./storage    Railway: /data  (the mounted volume)
FILE_STORAGE_DIR="./storage"

# The public URL of the app. Local: http://localhost:3000
# Railway: your Railway-provided URL or custom domain (https://...).
AUTH_URL="http://localhost:3000"

# First-run admin bootstrap (used only by the seed script). Change these!
SEED_ADMIN_EMAIL="office@llewellynplumbing.com"
SEED_ADMIN_PASSWORD="ChangeMe!2026"
